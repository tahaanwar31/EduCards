{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/v1/subjects",
      "destination": "/api/v1/list-subjects"
    },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
