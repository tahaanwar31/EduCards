{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/v1/(.*)", "destination": "/api/v1/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
