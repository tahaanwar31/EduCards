@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap');
@import "tailwindcss";

@theme {
  --font-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
  --font-mono: "JetBrains Mono", ui-monospace, SFMono-Regular, monospace;
}

@layer utilities {
  .preserve-3d {
    transform-style: preserve-3d;
  }
  .backface-hidden {
    backface-visibility: hidden;
  }
  .perspective-1000 {
    perspective: 1000px;
  }
  .bg-dot-white {
    background-image: url("data:image/svg+xml,%3Csvg width='24' height='24' viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='2' cy='2' r='1' fill='%23ffffff' fill-opacity='0.07'/%3E%3C/svg%3E");
  }
  .bg-grid-white {
    background-image: 
      linear-gradient(to right, rgba(255,255,255,0.04) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .glass-card {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }
  .glass-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.12);
  }
  .btn-primary {
    background: linear-gradient(135deg, #ff5c6c 0%, #4F46E5 100%);
    box-shadow: 0 0 20px rgba(255, 92, 108, 0.25), 0 0 60px rgba(79, 70, 229, 0.1), inset 0 1px 0 rgba(255,255,255,0.15);
  }
  .btn-primary:hover {
    box-shadow: 0 0 30px rgba(255, 92, 108, 0.4), 0 0 80px rgba(79, 70, 229, 0.2), inset 0 1px 0 rgba(255,255,255,0.2);
  }
  .btn-glass {
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2), inset 0 1px 0 rgba(255,255,255,0.06);
  }
  .btn-glass:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.3), inset 0 1px 0 rgba(255,255,255,0.1);
  }
  .card-shine::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.12) 50%, transparent 100%);
    z-index: 1;
  }
}

@layer components {
  .animate-gradient-x {
    background-size: 200% 200%;
    animation: gradient-x 4s ease infinite;
  }
  .animate-grain {
    animation: grain 8s steps(10) infinite;
  }
}

@keyframes gradient-x {
  0%, 100% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
}

@keyframes grain {
  0%, 100% { transform: translate(0, 0); }
  10% { transform: translate(-5%, -10%); }
  20% { transform: translate(-15%, 5%); }
  30% { transform: translate(7%, -25%); }
  40% { transform: translate(-5%, 25%); }
  50% { transform: translate(-15%, 10%); }
  60% { transform: translate(15%, 0%); }
  70% { transform: translate(0%, 15%); }
  80% { transform: translate(3%, 35%); }
  90% { transform: translate(-10%, 10%); }
}

@keyframes orb-float-1 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  25% { transform: translate(50px, -80px) scale(1.1); }
  50% { transform: translate(-30px, 60px) scale(0.9); }
  75% { transform: translate(40px, 30px) scale(1.05); }
}

@keyframes orb-float-2 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(-60px, 40px) scale(1.15); }
  66% { transform: translate(40px, -50px) scale(0.85); }
}

@keyframes orb-float-3 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  20% { transform: translate(80px, -30px) scale(0.95); }
  40% { transform: translate(-40px, -60px) scale(1.1); }
  60% { transform: translate(30px, 80px) scale(1); }
  80% { transform: translate(-60px, 20px) scale(0.9); }
}

@keyframes orb-float-4 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50% { transform: translate(60px, -40px) scale(1.08); }
}

@keyframes shimmer {
  0% { transform: translateX(-100%); }
  50% { transform: translateX(100%); }
  100% { transform: translateX(100%); }
}

@keyframes blob-1 {
  0%, 100% { transform: translate(0, 0) scale(1) rotate(0deg); }
  15% { transform: translate(60px, -80px) scale(1.15) rotate(10deg); }
  30% { transform: translate(-40px, 50px) scale(0.9) rotate(-15deg); }
  50% { transform: translate(100px, 30px) scale(1.2) rotate(20deg); }
  70% { transform: translate(-60px, -60px) scale(0.85) rotate(-10deg); }
  85% { transform: translate(30px, 80px) scale(1.1) rotate(5deg); }
}

@keyframes blob-2 {
  0%, 100% { transform: translate(0, 0) scale(1) rotate(0deg); }
  20% { transform: translate(-90px, 60px) scale(1.2) rotate(-20deg); }
  40% { transform: translate(70px, -70px) scale(0.8) rotate(15deg); }
  60% { transform: translate(-50px, -30px) scale(1.15) rotate(-5deg); }
  80% { transform: translate(80px, 50px) scale(0.9) rotate(10deg); }
}

@keyframes blob-3 {
  0%, 100% { transform: translate(0, 0) scale(1) rotate(0deg); }
  25% { transform: translate(80px, -50px) scale(1.1) rotate(25deg); }
  50% { transform: translate(-70px, 80px) scale(0.85) rotate(-20deg); }
  75% { transform: translate(40px, -30px) scale(1.2) rotate(15deg); }
}

@keyframes blob-4 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(-100px, 70px) scale(1.25); }
  66% { transform: translate(80px, -60px) scale(0.8); }
}

@keyframes blob-5 {
  0%, 100% { transform: translate(0, 0) scale(1) rotate(0deg); }
  20% { transform: translate(60px, 40px) scale(1.1) rotate(-10deg); }
  40% { transform: translate(-80px, -50px) scale(0.9) rotate(20deg); }
  60% { transform: translate(40px, -80px) scale(1.15) rotate(-15deg); }
  80% { transform: translate(-30px, 60px) scale(0.95) rotate(5deg); }
}

@keyframes streak-1 {
  0%, 100% { opacity: 0; transform: rotate(-15deg) translateX(-20%); }
  30% { opacity: 1; }
  50% { opacity: 1; transform: rotate(-15deg) translateX(10%); }
  80% { opacity: 0; }
}

@keyframes streak-2 {
  0%, 100% { opacity: 0; transform: rotate(8deg) translateX(20%); }
  20% { opacity: 0; }
  40% { opacity: 0.8; }
  60% { opacity: 0.8; transform: rotate(8deg) translateX(-5%); }
  90% { opacity: 0; }
}

@keyframes streak-3 {
  0%, 100% { opacity: 0; transform: rotate(-5deg) translateX(-10%); }
  40% { opacity: 0; }
  55% { opacity: 0.7; }
  70% { opacity: 0.7; transform: rotate(-5deg) translateX(5%); }
  95% { opacity: 0; }
}

@keyframes float-particle-1 {
  0%, 100% { transform: translate(0, 0); opacity: 0.3; }
  25% { transform: translate(30px, -50px); opacity: 0.8; }
  50% { transform: translate(-20px, -100px); opacity: 0.4; }
  75% { transform: translate(10px, -40px); opacity: 0.7; }
}

@keyframes float-particle-2 {
  0%, 100% { transform: translate(0, 0); opacity: 0.4; }
  30% { transform: translate(-40px, -60px); opacity: 0.9; }
  60% { transform: translate(20px, -120px); opacity: 0.3; }
}

@keyframes float-particle-3 {
  0%, 100% { transform: translate(0, 0); opacity: 0.3; }
  20% { transform: translate(50px, -30px); opacity: 0.6; }
  40% { transform: translate(-30px, -80px); opacity: 0.9; }
  60% { transform: translate(20px, -110px); opacity: 0.4; }
  80% { transform: translate(-10px, -50px); opacity: 0.7; }
}

@keyframes float-particle-4 {
  0%, 100% { transform: translate(0, 0); opacity: 0.2; }
  50% { transform: translate(40px, -90px); opacity: 0.6; }
}

@keyframes float-particle-5 {
  0%, 100% { transform: translate(0, 0); opacity: 0.3; }
  35% { transform: translate(-50px, -40px); opacity: 0.8; }
  70% { transform: translate(30px, -100px); opacity: 0.3; }
}

@keyframes float-particle-6 {
  0%, 100% { transform: translate(0, 0); opacity: 0.15; }
  25% { transform: translate(60px, -70px); opacity: 0.5; }
  50% { transform: translate(-20px, -130px); opacity: 0.2; }
  75% { transform: translate(40px, -60px); opacity: 0.6; }
}

@layer components {
  .animate-orb-1 {
    animation: orb-float-1 20s ease-in-out infinite;
  }
  .animate-orb-2 {
    animation: orb-float-2 25s ease-in-out infinite;
  }
  .animate-orb-3 {
    animation: orb-float-3 30s ease-in-out infinite;
  }
  .animate-orb-4 {
    animation: orb-float-4 22s ease-in-out infinite;
  }
  .animate-shimmer {
    animation: shimmer 3s ease-in-out infinite;
  }
  .animate-blob-1 {
    animation: blob-1 18s ease-in-out infinite;
  }
  .animate-blob-2 {
    animation: blob-2 22s ease-in-out infinite;
  }
  .animate-blob-3 {
    animation: blob-3 26s ease-in-out infinite;
  }
  .animate-blob-4 {
    animation: blob-4 20s ease-in-out infinite;
  }
  .animate-blob-5 {
    animation: blob-5 24s ease-in-out infinite;
  }
  .animate-streak-1 {
    animation: streak-1 8s ease-in-out infinite;
  }
  .animate-streak-2 {
    animation: streak-2 10s ease-in-out infinite;
  }
  .animate-streak-3 {
    animation: streak-3 12s ease-in-out infinite;
  }
  .animate-float-particle-1 {
    animation: float-particle-1 12s ease-in-out infinite;
  }
  .animate-float-particle-2 {
    animation: float-particle-2 15s ease-in-out infinite;
  }
  .animate-float-particle-3 {
    animation: float-particle-3 10s ease-in-out infinite;
  }
  .animate-float-particle-4 {
    animation: float-particle-4 18s ease-in-out infinite;
  }
  .animate-float-particle-5 {
    animation: float-particle-5 13s ease-in-out infinite;
  }
  .animate-float-particle-6 {
    animation: float-particle-6 16s ease-in-out infinite;
  }
}

@keyframes btn-shine {
  0% { left: -100%; }
  20% { left: 100%; }
  100% { left: 100%; }
}

@layer utilities {
  .btn-shine-effect {
    position: relative;
    overflow: hidden;
  }
  .btn-shine-effect::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
    animation: btn-shine 4s ease-in-out infinite;
  }
}

