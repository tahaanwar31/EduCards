        <div className="absolute top-[-20%] left-[-10%] w-[60vw] h-[60vw] rounded-full bg-[#a855f7] mix-blend-screen blur-[120px] opacity-[0.30] animate-blob-1"></div>
        <div className="absolute top-[-5%] right-[-15%] w-[55vw] h-[55vw] rounded-full bg-[#ff5c6c] mix-blend-screen blur-[120px] opacity-[0.25] animate-blob-2"></div>
        <div className="absolute bottom-[-25%] left-[20%] w-[65vw] h-[65vw] rounded-full bg-[#4F46E5] mix-blend-screen blur-[140px] opacity-[0.28] animate-blob-3"></div>
        <div className="absolute top-[30%] left-[50%] w-[45vw] h-[45vw] rounded-full bg-[#ff8a3d] mix-blend-screen blur-[130px] opacity-[0.12] animate-blob-4"></div>
        <div className="absolute bottom-[10%] right-[5%] w-[50vw] h-[50vw] rounded-full bg-[#06b6d4] mix-blend-screen blur-[150px] opacity-[0.10] animate-blob-5"></div>

        {/* Animated gradient streaks */}
        <div className="absolute top-0 left-0 w-full h-full">
          <div className="absolute top-[15%] left-[-20%] w-[140%] h-[2px] bg-gradient-to-r from-transparent via-[#a855f7]/30 to-transparent rotate-[-15deg] animate-streak-1"></div>
          <div className="absolute top-[45%] left-[-20%] w-[140%] h-[1px] bg-gradient-to-r from-transparent via-[#ff5c6c]/20 to-transparent rotate-[8deg] animate-streak-2"></div>
