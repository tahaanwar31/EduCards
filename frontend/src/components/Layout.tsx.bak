        <div className="absolute w-1.5 h-1.5 rounded-full bg-[#a855f7]/40 top-[60%] left-[80%] animate-float-particle-2"></div>
        <div className="absolute w-1 h-1 rounded-full bg-[#ff5c6c]/30 top-[40%] left-[45%] animate-float-particle-3"></div>
